# Expo public env vars (available on client)
EXPO_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
EXPO_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# RevenueCat (subscriptions) — use Public API keys from RevenueCat dashboard
# Android (use either name; both supported):
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY="goog_xxxx"
# EXPO_PUBLIC_RC_ANDROID="goog_xxxx"
# iOS:
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY="appl_xxxx"
# EXPO_PUBLIC_RC_IOS="appl_xxxx"

# Optional (for scripts that insert into hand_library)
# SUPABASE_SERVICE_ROLE_KEY="your_service_role_key"
# OPENAI_API_KEY="your_openai_key"
